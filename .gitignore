# ---- Roomi Arts POS: never commit business data or secrets ----
# Local SQLite database and its journal/WAL files (real shop data, contains
# hashed staff passwords). The app creates these at runtime.
*.db
*.db-journal
*.db-wal
*.db-shm
*.sqlite
*.sqlite3
roomi_arts*.db
*.rollback

# Backups produced by the in-app Backup feature
roomi_arts_backup_*.db
backups/

# Secrets / local config (if any are ever added)
.env
.env.*
secrets.json
*.secret
